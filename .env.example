NVIDIA_API_KEY=your_key_here

# API Server Configuration (for nvidia_garak testing)
GUARDRAILS_MODE=guarded         # "guarded" or "unguarded"
API_HOST=0.0.0.0                # Host to bind the API server
API_PORT=8000                   # Port to bind the API server
REQUEST_TIMEOUT=60              # Max seconds to wait for upstream response (prevents infinite hangs)
NIM_RATE_LIMIT=40               # Max API calls per minute to NVIDIA NIM
